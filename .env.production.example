# Sen React — Vercel "Production" environment contract
#
# These env vars must be set on each Vercel project, scoped to the
# "production" target. Use the REST API per
# memory/payload-nextjs-supabase-bootstrap.md §3.4:
#
#   curl -X POST "https://api.vercel.com/v10/projects/<id>/env?teamId=<team>&upsert=true" \
#     -H "Authorization: Bearer $VERCEL_TOKEN" \
#     -d '{"key":"<KEY>","value":"<VAL>","target":["production"],"type":"encrypted"}'
#
# The values in this file are the *contract*, not the secrets. Real values
# live on the Vercel project.

# ─────────── Apps/web (sen-react project) ───────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # encrypted

# Payload CMS URL — stable prod alias for the apps/cms deploy.
NEXT_PUBLIC_CMS_URL=https://sen-react-cms.vercel.app

# ─────────── Apps/cms (sen-react-cms project) ───────────────────────────

DATABASE_URL=  # encrypted; Supabase pooler host (aws-1-eu-west-3, port 6543)
PAYLOAD_SECRET=  # encrypted

NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # encrypted
SUPABASE_SERVICE_ROLE_KEY=  # encrypted

# ─────────── Operational notes ──────────────────────────────────────────
#
# - Branch protection on `main` requires status check
#   "Lint, format, typecheck, build" — production deploys only fire from
#   merged PRs.
#
# - The CMS build runs `pnpm migrate` before `next build` via a
#   `vercel-build` script. The first migration created the payload schema
#   in Supabase; subsequent migrations are picked up automatically on
#   each prod deploy.
#
# - SSO protection: disabled (`ssoProtection: null` — public-facing
#   non-profit). Decision recorded in docs/phase-0-validation.md
#   §"Preview protection decision".
