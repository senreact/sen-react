# Sen React — Vercel "Preview" environment contract
#
# These env vars must be set on each Vercel project, scoped to the "preview"
# target. Use the REST API or `vercel env add … preview` (note: CLI has a
# `git_branch_required` bug — REST is the documented workaround):
#
#   curl -X POST "https://api.vercel.com/v10/projects/<id>/env?teamId=<team>&upsert=true" \
#     -H "Authorization: Bearer $VERCEL_TOKEN" \
#     -d '{"key":"<KEY>","value":"<VAL>","target":["preview"],"type":"encrypted"}'
#
# The values in this file are the *contract*, not the secrets. Real values
# live on the Vercel project. Both projects (sen-react = apps/web and
# sen-react-cms = apps/cms) share the same Supabase + Payload secrets at
# this stage; that may diverge if we ever add a preview-only Supabase.

# ─────────── Apps/web (sen-react project) ───────────────────────────────

# Supabase auth — same as production for now. Preview previews that
# trigger Supabase signups will land in the prod auth.users table; that's
# acceptable for sen-react's scale. Switch to a preview Supabase once
# preview signups become noisy.
NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # encrypted on Vercel; copy from prod for now

# Payload CMS URL — preview apps/web hits the live CMS. The Vercel preview
# URL on apps/cms changes per deploy, so we point at the stable prod alias
# rather than chasing per-deploy URLs.
NEXT_PUBLIC_CMS_URL=https://sen-react-cms.vercel.app

# ─────────── Apps/cms (sen-react-cms project) ───────────────────────────

# Postgres connection — same Supabase project as prod. Migrations apply
# to the same payload schema; if a preview build runs migrations it will
# affect prod too. Mitigation: only push migration files via main branch.
DATABASE_URL=  # encrypted on Vercel; copy from prod
PAYLOAD_SECRET=  # encrypted on Vercel; copy from prod

# Same Supabase keys for media uploads etc. (apps/cms doesn't currently
# use Supabase auth but the keys are wired for future Storage use)
NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # encrypted on Vercel
SUPABASE_SERVICE_ROLE_KEY=  # encrypted on Vercel

# ─────────── Notes ──────────────────────────────────────────────────────
#
# - SSO protection: disabled on both projects (`ssoProtection: null` —
#   public-facing non-profit). Decision recorded in
#   docs/phase-0-validation.md §"Preview protection decision".
#
# - Branch ref in the Vercel deploy event is the same for both projects;
#   the e2e workflow's concurrency key includes `environment` to keep
#   per-project runs from cancelling each other.
