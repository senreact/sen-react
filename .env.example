# Sen React — environment variables (local dev template)
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` to git.
#
# For preview / production deployment env vars, see:
#   .env.preview.example   — Vercel "Preview" environment contract
#   .env.production.example — Vercel "Production" environment contract

# ──────────────────────────────────────────────────────────────────────────────
# Supabase — project ref `lhieyipykopqyeydrwoo` (sen-react, eu-west-3 Paris)
# Account: tom.shields001@gmail.com
# Dashboard: https://supabase.com/dashboard/project/lhieyipykopqyeydrwoo
# ──────────────────────────────────────────────────────────────────────────────

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for Payload CMS — lands in PR-0a-ii)
# Format: postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
# Verify pooler host with: GET https://api.supabase.com/v1/projects/<ref>/config/database/pooler
# URL-encode special chars in the password (& % $ ^ * etc.)
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Payload CMS (lands in PR-0a-ii)
# ──────────────────────────────────────────────────────────────────────────────

PAYLOAD_SECRET=

# Supabase Storage bucket for Payload media uploads (PDFs, images, subtitles).
# Default `sen-react-media` (public-read). Created programmatically — see
# scripts/setup-storage.sh for the curl payload.
SUPABASE_STORAGE_BUCKET=sen-react-media

# ──────────────────────────────────────────────────────────────────────────────
# Payload CMS — public URL apps/web reads to fetch globals + collections.
# In local dev: typically unset (apps/web falls back to DEFAULT_* + empty
# lists). Set to https://sen-react-cms.vercel.app to talk to the live CMS
# from a local apps/web instance.
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_CMS_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Vercel — personal access token scoped to tomasi001s-projects
# Create at https://vercel.com/account/tokens
# ──────────────────────────────────────────────────────────────────────────────

VERCEL_TOKEN=
