# Sen React — environment variables (template)
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` to git.

# ──────────────────────────────────────────────────────────────────────────────
# Supabase — project ref `lhieyipykopqyeydrwoo` (sen-react, eu-west-3 Paris)
# Account: tom.shields001@gmail.com
# Dashboard: https://supabase.com/dashboard/project/lhieyipykopqyeydrwoo
# ──────────────────────────────────────────────────────────────────────────────

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://lhieyipykopqyeydrwoo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for Payload CMS — lands in PR-0a-ii)
# Format: postgres://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
# Verify pooler host with: GET https://api.supabase.com/v1/projects/<ref>/config/database/pooler
# URL-encode special chars in the password (& % $ ^ * etc.)
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Payload CMS (lands in PR-0a-ii)
# ──────────────────────────────────────────────────────────────────────────────

PAYLOAD_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Vercel — personal access token scoped to tomasi001s-projects
# Create at https://vercel.com/account/tokens
# ──────────────────────────────────────────────────────────────────────────────

VERCEL_TOKEN=
